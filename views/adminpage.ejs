        <section id="account" class="tab-content">
            <div class="headermenu">
                <h2>ACCOUNT</h2>
                <form action="" class="add">
                    <button type="button" onclick="toggleForm('edit_profile')" class="add-btn">Edit Profile</button>
                </form>
            </div>

            <div class="container-menu">
                <div class="container5">
                    <div class="Profile">
                        <!-- Logic: Kung may uploaded picture, gamitin yun. Kung wala, gamitin ang default. -->
                        <img src="<%= (typeof employeeProfile !== 'undefined' && employeeProfile.PROFILE_PIC) ? employeeProfile.PROFILE_PIC : '/default-avatar.png' %>" alt="Profile Picture" class="profile-pic">
                        <span class="name1"><%= USERNAME %></span>
                        <span class="role1"><%= CATEGORY %></span>
                    </div>

                    <div class="details">
                        <p>Full Name : <%= (typeof employeeProfile !== 'undefined' && employeeProfile.FULL_NAME) ? employeeProfile.FULL_NAME : 'Not Set' %></p>
                        <p>Position : <%= (typeof employeeProfile !== 'undefined' && employeeProfile.POSITION) ? employeeProfile.POSITION : 'Not Set' %></p>
                        <p>Contact Number : <%= (typeof employeeProfile !== 'undefined' && employeeProfile.CONTACT_NO) ? employeeProfile.CONTACT_NO : 'Not Set' %></p>
                        <p>Home Address : <%= (typeof employeeProfile !== 'undefined' && employeeProfile.HOME_ADDRESS) ? employeeProfile.HOME_ADDRESS : 'Not Set' %></p>
                    </div>
                </div>

                <div class="container7" id="edit_profile">
                    <section>
                        <!-- Importante: 'enctype="multipart/form-data"' ay kailangan para sa file upload -->
                        <form action="/update-profile" method="POST" class="edit" enctype="multipart/form-data">

                            <div>
                                <label for="">Full Name</label>
                                <input type="text" name="full_name" id="name" value="<%= (typeof employeeProfile !== 'undefined' && employeeProfile.FULL_NAME) ? employeeProfile.FULL_NAME : '' %>" placeholder="Full Name">
                            </div>

                            <div>
                                <label for="">Position</label>
                                <input type="text" name="position" id="position" value="<%= (typeof employeeProfile !== 'undefined' && employeeProfile.POSITION) ? employeeProfile.POSITION : '' %>" placeholder="Position">
                            </div>

                            <div>
                                <label for="">Contact Number</label>
                                <input type="text" name="contact_no" id="contact" value="<%= (typeof employeeProfile !== 'undefined' && employeeProfile.CONTACT_NO) ? employeeProfile.CONTACT_NO : '' %>" placeholder="Contact Number">
                            </div>

                            <div>
                                <label for="">Home Address</label>
                                <input type="text" name="home_address" id="address" value="<%= (typeof employeeProfile !== 'undefined' && employeeProfile.HOME_ADDRESS) ? employeeProfile.HOME_ADDRESS : '' %>" placeholder="Home Address">
                            </div>

                            <div>
                                <label for="Profile">Upload Profile Picture</label>
                                <input type="file" name="profile_pic" id="Profile" accept="image/*">
                            </div>

                            <button type="submit" class="add-item-btn">Save Changes</button>
                        </form>
                    </section>
                </div>

            </div>
        </section>
    </main>

    <!-- PDF Generation Libraries -->
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jspdf/1.5.3/jspdf.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jspdf-autotable/3.5.6/jspdf.plugin.autotable.min.js"></script>
    <!-- Chart.js Library -->
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    
    <script src="userpagev2_script.js"></script>
    <!-- Hidden data elements to pass server data to JavaScript without EJS parsing issues -->
    <script id="salesByCategoryData" type="application/json"><%- JSON.stringify(analyticsData.salesByCategory || []) %></script>
    <script id="salesByCategory2Data" type="application/json"><%- JSON.stringify(analyticsData.salesByCategory2 || []) %></script>
    <script id="salesByMonthData" type="application/json"><%- JSON.stringify(analyticsData.salesByMonth || []) %></script>
    <script id="salesByDailyData" type="application/json"><%- JSON.stringify(analyticsData.salesByDaily || []) %></script>
    <script id="attendanceStatsData" type="application/json"><%- JSON.stringify(analyticsData.attendanceStats || { Present: 0, Late: 0, Undertime: 0, HalfDay: 0 }) %></script>
    <script id="salesByMonthCat2Data" type="application/json"><%- JSON.stringify(analyticsData.salesByMonthCat2 || []) %></script>
    <script id="salesByDailyCat2Data" type="application/json"><%- JSON.stringify(analyticsData.salesByDailyCat2 || []) %></script>
    <script id="latesPerUserData" type="application/json"><%- JSON.stringify(analyticsData.latesPerUser || {}) %></script>

    <script>
        // Data from server - stored in data attributes to avoid JS parser issues
        const salesByCategoryData = JSON.parse(document.getElementById('salesByCategoryData').textContent);
        // Script para basahin ang ?tab= parameter sa URL
        document.addEventListener("DOMContentLoaded", function() {
            // --- CHART.JS INITIALIZATION ---
            
            if (salesByCategoryData && salesByCategoryData.length > 0) {
                const ctx = document.getElementById('salesByCategoryChart').getContext('2d');
                
                const labels = salesByCategoryData.map(item => item.CATEGORY);
                const data = salesByCategoryData.map(item => item.categorySales);

                new Chart(ctx, {
                    type: 'bar', // CHANGED TO BAR CHART
                    data: {
                        labels: labels,
                        datasets: [{
                            label: 'Sales',
                            data: data,
                            backgroundColor: [
                                '#4E342E', // secondary-brown
                                '#795548', // primary-brown
                                '#D4AF37', // accent-gold
                                '#A1887F',
                                '#BCAAA4',
                            ],
                            borderColor: '#FAF9F6',
                            borderWidth: 1
                        }]
                    },
                    options: {
                        responsive: true,
                        plugins: {
                            legend: {
                                display: false, // Hide legend for bar chart usually
                            },
                            tooltip: {
                                callbacks: { label: function(c) { return ' Sales: ₱ ' + c.parsed.y.toLocaleString(); } }
                            }
                        },
                        scales: {
                            y: { beginAtZero: true }
                        }
                    }
                });
            }

            // --- CHART 1.5: SALES BY CATEGORY 2 (NEW BAR CHART) ---
            const salesByCategory2Data = JSON.parse(document.getElementById('salesByCategory2Data').textContent);
            
            if (salesByCategory2Data && salesByCategory2Data.length > 0) {
                const ctxCat2 = document.getElementById('salesByCategory2Chart').getContext('2d');
                
                const labels2 = salesByCategory2Data.map(item => item.CATEGORY);
                const data2 = salesByCategory2Data.map(item => item.categorySales);

                new Chart(ctxCat2, {
                    type: 'bar',
                    data: {
                        labels: labels2,
                        datasets: [{
                            label: 'Sales',
                            data: data2,
                            backgroundColor: '#4E342E', // Solid color for distinction
                            borderColor: '#FAF9F6',
                            borderWidth: 1
                        }]
                    },
                    options: {
                        responsive: true,
                        plugins: {
                            legend: { display: false },
                            tooltip: { callbacks: { label: function(c) { return ' Sales: ₱ ' + c.parsed.y.toLocaleString(); } } }
                        },
                        scales: {
                            y: { beginAtZero: true }
                        }
                    }
                });
            }

            // --- CHART 2: MONTHLY SALES LINE GRAPH ---
            // Kunin ang data galing sa server
            const salesByMonthData = JSON.parse(document.getElementById('salesByMonthData').textContent);

            if (salesByMonthData && salesByMonthData.length > 0) {
                const ctx2 = document.getElementById('salesByMonthChart').getContext('2d');
                
                // I-map ang labels (Buwan) at data (Total Sales)
                const labelsMonth = salesByMonthData.map(item => item.monthLabel);
                const dataMonth = salesByMonthData.map(item => parseFloat(item.totalSales));

                new Chart(ctx2, {
                    type: 'line', // Line graph
                    data: {
                        labels: labelsMonth,
                        datasets: [{
                            label: 'Total Sales (₱)',
                            data: dataMonth,
                            backgroundColor: 'rgba(212, 175, 55, 0.2)', // Accent gold (transparent)
                            borderColor: '#D4AF37', // Accent gold (solid)
                            borderWidth: 3,
                            fill: true, // Lagyan ng kulay sa ilalim ng linya
                            tension: 0.3 // Gawing curve ang linya
                        }]
                    },
                    options: {
                        responsive: true,
                        plugins: {
                            legend: { position: 'top' },
                            tooltip: {
                                callbacks: {
                                    label: function(context) {
                                        return ' Sales: ₱ ' + context.parsed.y.toLocaleString();
                                    }
                                }
                            }
                        },
                        scales: {
                            y: {
                                beginAtZero: true,
                                ticks: {
                                    callback: function(value) { return '₱' + value; }
                                }
                            }
                        }
                    }
                });
            }

            // --- CHART 3: DAILY SALES TREND (NEW) ---
            const salesByDailyData = JSON.parse(document.getElementById('salesByDailyData').textContent);

            if (salesByDailyData && salesByDailyData.length > 0) {
                const ctx3 = document.getElementById('salesByDailyChart').getContext('2d');
                
                const labelsDaily = salesByDailyData.map(item => item.dateLabel);
                const dataDaily = salesByDailyData.map(item => parseFloat(item.totalSales));

                new Chart(ctx3, {
                    type: 'line',
                    data: {
                        labels: labelsDaily,
                        datasets: [{
                            label: 'Daily Sales (₱)',
                            data: dataDaily,
                            backgroundColor: 'rgba(78, 52, 46, 0.2)', // Secondary brown (transparent)
                            borderColor: '#4E342E', // Secondary brown (solid)
                            borderWidth: 2,
                            fill: true,
                            tension: 0.3 // Smooth curves
                        }]
                    },
                    options: {
                        responsive: true,
                        plugins: {
                            legend: { position: 'top' },
                            tooltip: {
                                callbacks: { label: function(c) { return ' Sales: ₱ ' + c.parsed.y.toLocaleString(); } }
                            }
                        },
                        scales: { y: { beginAtZero: true, ticks: { callback: function(v) { return '₱' + v; } } } }
                    }
                });
            }

            // --- CHART 4: ATTENDANCE STATUS (BAR CHART) ---
            const attendanceStats = JSON.parse(document.getElementById('attendanceStatsData').textContent);
            const ctxAtt = document.getElementById('attendanceChart').getContext('2d');
            
            new Chart(ctxAtt, {
                type: 'bar',
                data: {
                    labels: ['Present (On Time)', 'Late', 'Undertime', 'Half Day'],
                    datasets: [{
                        label: 'Count',
                        data: [
                            attendanceStats.Present,
                            attendanceStats.Late,
                            attendanceStats.Undertime,
                            attendanceStats.HalfDay
                        ],
                        backgroundColor: [
                            '#4E342E', // Present (Dark Brown)
                            '#D4AF37', // Late (Gold - Warning)
                            '#795548', // Undertime (Primary Brown)
                            '#A1887F'  // Half Day (Light Brown)
                        ],
                        borderColor: '#FAF9F6',
                        borderWidth: 1
                    }]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    plugins: {
                        legend: { display: false }
                    },
                    scales: {
                        y: {
                            beginAtZero: true,
                            ticks: { stepSize: 1 }
                        }
                    }
                }
            });

            // --- CHART 5: MONTHLY SALES TREND CATEGORY 2 (LINE CHART) ---
            const salesByMonthCat2Data = JSON.parse(document.getElementById('salesByMonthCat2Data').textContent);

            // --- HELPER: Process Data for Multi-Category Charts (Grouped Bar) ---
            function transformDataForChart(data, labelKey, categoryKey, valueKey) {
                // 1. Unique Labels (Dates) for X-Axis
                const labels = [...new Set(data.map(d => d[labelKey]))];
                // 2. Unique Categories for Series/Legend
                const categories = [...new Set(data.map(d => d[categoryKey]))];
                
                // 3. Colors Palette
                const colors = ['#4E342E', '#D4AF37', '#795548', '#A1887F', '#5D4037', '#8D6E63', '#3E2723'];

                // 4. Create Datasets
                const datasets = categories.map((cat, i) => {
                    return {
                        label: cat, // Category Name appears in Legend
                        data: labels.map(lbl => {
                            const found = data.find(d => d[labelKey] === lbl && d[categoryKey] === cat);
                            return found ? parseFloat(found[valueKey]) : 0;
                        }),
                        borderColor: colors[i % colors.length],
                        backgroundColor: colors[i % colors.length],
                        fill: false,
                        tension: 0.3,
                        borderWidth: 2
                    };
                });
                return { labels, datasets };
            }

            if (salesByMonthCat2Data && salesByMonthCat2Data.length > 0) {
                const ctxM2 = document.getElementById('salesByMonthCat2Chart').getContext('2d');
                
                const chartData = transformDataForChart(salesByMonthCat2Data, 'monthLabel', 'category', 'totalSales');

                new Chart(ctxM2, {
                    type: 'line',
                    data: {
                        labels: chartData.labels,
                        datasets: chartData.datasets
                    },
                    options: {
                        responsive: true,
                        plugins: {
                            legend: { display: true, position: 'top' },
                            tooltip: {
                                callbacks: {
                                    label: function(context) { 
                                        return context.dataset.label + ': ₱ ' + context.parsed.y.toLocaleString(); 
                                    }
                                }
                            }
                        },
                        scales: {
                            y: { beginAtZero: true, ticks: { callback: function(value) { return '₱' + value; } } }
                        }
                    }
                });
            }

            // --- CHART 6: DAILY SALES TREND CATEGORY 2 (LINE CHART) ---
            const salesByDailyCat2Data = JSON.parse(document.getElementById('salesByDailyCat2Data').textContent);

            if (salesByDailyCat2Data && salesByDailyCat2Data.length > 0) {
                const ctxD2 = document.getElementById('salesByDailyCat2Chart').getContext('2d');
                
                const chartDataD = transformDataForChart(salesByDailyCat2Data, 'dateLabel', 'category', 'totalSales');

                new Chart(ctxD2, {
                    type: 'line',
                    data: {
                        labels: chartDataD.labels,
                        datasets: chartDataD.datasets
                    },
                    options: {
                        responsive: true,
                        plugins: {
                            legend: { display: true, position: 'top' },
                            tooltip: {
                                callbacks: { label: function(c) { return c.dataset.label + ': ₱ ' + c.parsed.y.toLocaleString(); } }
                            }
                        },
                        scales: { y: { beginAtZero: true, ticks: { callback: function(v) { return '₱' + v; } } } }
                    }
                });
            }

            // --- CHART 7: LATES PER USER (BAR CHART - LEGEND AS NAMES) ---
            const latesRaw = JSON.parse(document.getElementById('latesPerUserData').textContent);
            const latesUsers = Object.keys(latesRaw);

            if (latesUsers.length > 0) {
                const ctxLates = document.getElementById('latesPerUserChart').getContext('2d');
                const coffeeColors = ['#4E342E', '#D4AF37', '#795548', '#A1887F', '#5D4037', '#8D6E63', '#3E2723'];

                // Create a separate dataset for each user so they appear in the Legend
                const datasetsLates = latesUsers.map((user, index) => {
                    return {
                        label: user, // Name in Legend
                        data: [latesRaw[user]], // Late Count
                        backgroundColor: coffeeColors[index % coffeeColors.length],
                        borderColor: '#FAF9F6',
                        borderWidth: 1
                    };
                });

                new Chart(ctxLates, {
                    type: 'bar',
                    data: {
                        labels: ['Total Lates'], // X-Axis Label
                        datasets: datasetsLates
                    },
                    options: {
                        responsive: true,
                        plugins: { legend: { display: true, position: 'top' } },
                        scales: { y: { beginAtZero: true, ticks: { stepSize: 1 } } }
                    }
                });
            }

            const urlParams = new URLSearchParams(window.location.search);
            const tab = urlParams.get('tab');
            const sub = urlParams.get('sub');
            
            if (tab) {
                openSection(tab);
            }

            // Initialize Dropdowns for all tables
            populateDropdowns('inventoryTable');
            populateDropdowns('selloutTable');
            populateDropdowns('attendanceTable');
            populateDropdowns('usersTable');
            
            // Tiyaking maayos ang Manning Table filter
            const manningTable = document.getElementById('manningTable');
            if (manningTable) {
                manningTable.classList.add('filterable-table');
            }
            
            populateDropdowns('manningTable');
        });

        // Function to populate dropdowns automatically based on table data
        function populateDropdowns(tableId) {
            var table = document.getElementById(tableId);
            if (!table) return;
            var tbody = table.querySelector("tbody");
            var rows = tbody.getElementsByTagName("tr");
            var filterRow = table.querySelector(".filter-row");
            var selects = filterRow.getElementsByTagName("select");

            // Loop through each filter column
            for (var i = 0; i < selects.length; i++) {
                var select = selects[i];
                var uniqueValues = new Set();

                // Collect unique values from this column
                for (var r = 0; r < rows.length; r++) {
                    var cells = rows[r].getElementsByTagName("td");
                    if (cells.length > i) {
                        var text = (cells[i].textContent || cells[i].innerText).trim();
                        if (text && text !== "No items found." && text !== "No records found.") {
                            uniqueValues.add(text);
                        }
                    }
                }

                // Add options to dropdown
                Array.from(uniqueValues).sort().forEach(function(val) {
                    var option = document.createElement("option");
                    option.value = val.toUpperCase(); // Store as uppercase for easier filtering
                    option.text = val;
                    select.appendChild(option);
                });
            }
        }

        // Updated Filter Function (Multi-column support)
        function filterTable(tableId) {
            var table = document.getElementById(tableId);
            var tbody = table.getElementsByTagName("tbody")[0];
            var tr = tbody.getElementsByTagName("tr");
            var filterRow = table.querySelector(".filter-row");
            var selects = filterRow.getElementsByTagName("select");

            // Loop through all table rows
            for (var i = 0; i < tr.length; i++) {
                var showRow = true;

                // Check each filter dropdown
                for (var j = 0; j < selects.length; j++) {
                    var filterVal = selects[j].value;
                    if (filterVal !== "") { // If a filter is selected
                        var td = tr[i].getElementsByTagName("td")[j];
                        if (td) {
                            var txtValue = (td.textContent || td.innerText).trim().toUpperCase();
                            // Exact match check
                            if (txtValue !== filterVal) {
                                showRow = false;
                                break; // Stop checking other columns if one fails
                            }
                        }
                    }
                }

                if (showRow) {
                    tr[i].style.display = "";
                } else {
                    tr[i].style.display = "none";
                }
            }
        }

        // Global Search Function for Menu Table
        function searchMenuTable() {
            var input = document.getElementById("menuSearchInput");
            var filter = input.value.toUpperCase();
            var table = document.getElementById("menuTable");
            var tbody = table.getElementsByTagName("tbody")[0];
            var tr = tbody.getElementsByTagName("tr");

            for (var i = 0; i < tr.length; i++) {
                var tds = tr[i].getElementsByTagName("td");
                var match = false;
                // Check columns: Name(0), Cat(1), Cat2(2), Price(3)
                if (tds.length > 0) {
                    for (var j = 0; j < 4; j++) {
                        if (tds[j] && (tds[j].textContent || tds[j].innerText).toUpperCase().indexOf(filter) > -1) {
                            match = true;
                            break;
                        }
                    }
                    tr[i].style.display = match ? "" : "none";
                }
            }
        }

        // Page Load Logic (Para manatili sa tamang tab pagkatapos mag-refresh/redirect)
        document.addEventListener("DOMContentLoaded", function() {
            const urlParams = new URLSearchParams(window.location.search);
            const tab = urlParams.get('tab');
            const sub = urlParams.get('sub');
            
            if (tab) openSection(tab);
            if (sub === 'Attendance') {
                toggleForm('Attendance');
            }
        });
    </script>
    
</body>
</html>