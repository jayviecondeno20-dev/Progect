                                        <td><%= new Date(row.TIMESTAMP).toLocaleString() %></td>
                                        <td><%= row.USERNAME %></td>
                                        <td><%= row.MENU %></td>
                                        <td><%= row.CATEGORY %></td>
                                        <td><%= row['CATEGORY 2'] %></td>
                                        <td>₱ <%= row.Price %></td>
                                        <td><%= row.Qty %></td>
                                        <td>₱ <%= row['Total Sellout'] %></td>
                                    </tr>
