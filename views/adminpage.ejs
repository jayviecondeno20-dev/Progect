                                <th><select class="filter-input" onchange="filterTable('selloutTable')"><option value="">All</option></select></th>
                                <th><select class="filter-input" onchange="filterTable('selloutTable')"><option value="">All</option></select></th>
                                <th><select class="filter-input" onchange="filterTable('selloutTable')"><option value="">All</option></select></th>
                                <th><select class="filter-input" onchange="filterTable('selloutTable')"><option value="">All</option></select></th>
                                <th><select class="filter-input" onchange="filterTable('selloutTable')"><option value="">All</option></select></th>
                                <th><select class="filter-input" onchange="filterTable('selloutTable')"><option value="">All</option></select></th>
                                <th><select class="filter-input" onchange="filterTable('selloutTable')"><option value="">All</option></select></th>
