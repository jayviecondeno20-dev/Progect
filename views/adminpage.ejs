<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title >ADMINPAGE</title>
    <link rel="icon" type="image/png" href="coffee-bean-solid-24.png">
    <link rel="stylesheet" href="adminpage.css">
    <link href='https://unpkg.com/boxicons@2.1.4/css/boxicons.min.css' rel='stylesheet'>
</head>
<body>
    <aside class="sidebar close">
        <header>
            <div class="image-text">
                <span class="image">
                    <img src="<%= (typeof employeeProfile !== 'undefined' && employeeProfile.PROFILE_PIC) ? employeeProfile.PROFILE_PIC : '/default-avatar.png' %>" alt="Profile Picture" class="profile-pic">
                </span>
                <div class="text header-text">
                    <span class="name"><%= USERNAME %></span>
                    <span class="role"><%= CATEGORY %></span>
                </div>
            </div>
        </header>

        <div class="menu-bar">
            <div class="menu">

                <ul class="menu-links">
                    <li class="nav-links">
                        <a href="#" onclick="openSection('analytics')">
                            <i class='bx bx-line-chart icon'></i>
                            <span class="text nav-text">ANALYTICS</span>
                        </a>
                    </li>
                </ul>

                <ul class="menu-links">
                    <li class="nav-links">
                        <a href="#" onclick="openSection('attendance')">
                            <i class='bx bx-calendar-check icon' ></i>
                            <span class="text nav-text">ATTENDANCE REPORTS</span>
                        </a>
                    </li>
                </ul>

                <ul class="menu-links">
                    <li class="nav-links">
                        <a href="#" onclick="openSection('inventory')">
                            <i class='bx bxs-box icon' ></i>
                            <span class="text nav-text">INVENTORY REPORTS</span>
                        </a>
                    </li>
                </ul>

                <ul class="menu-links">
                    <li class="nav-links">
                        <a href="#" onclick="openSection('sellout')">
                            <i class='bx bx-dollar-circle icon' ></i>
                            <span class="text nav-text">SELLOUT REPORTS</span>
                        </a>
                    </li>
                </ul>

                <ul class="menu-links">
                    <li class="nav-links">
                        <a href="#" onclick="openSection('menu')">
                            <i class='bx bxs-food-menu icon' ></i>
                            <span class="text nav-text">MENU</span>
                        </a>
                    </li>
                </ul>

                <ul class="menu-links">
                    <li class="nav-links">
                        <a href="#" onclick="openSection('users')">
                            <i class='bx bx-user-check icon'></i>
                            <span class="text nav-text">USER APPROVAL</span>
                        </a>
                    </li>
                </ul>

                <ul class="menu-links">
                    <li class="nav-links">
                        <a href="#" onclick="openSection('manning')">
                            <i class='bx bx-group icon'></i>
                            <span class="text nav-text">MANNING</span>
                        </a>
                    </li>
                </ul>

                <ul class="menu-links">
                    <li class="nav-links">
                        <a href="#" onclick="openSection('account')">
                            <i class='bx bxs-user-account icon' ></i>
                            <span class="text nav-text">ACCOUNT</span>
                        </a>
                    </li>
                </ul>
            </div>

            <DIV class="bottom-content">
                <ul class="menu-links">
                    <li class="nav-links">
                        <a href="#" onclick="event.preventDefault(); logoutUser();">
                            <i class='bx bx-log-out icon'></i>
                            <span class="text nav-text">LOGOUT</span>
                        </a>
                        <form id="logout-form" action="/logout?_method=DELETE" method="POST" style="display: none;"></form>
                    </li>
                </ul>
            </DIV>
        </div>
    </aside>

    <nav>
        <div>
            <i class='bx bx-menu hamburger-toggle'></i>
            <h1>ITAEWON KOPI SHOP</h1>
        </div>
    </nav>

    <main class="main-content">
        <% if (typeof errors !== 'undefined' && errors.length > 0) { %>
            <div class="alert alert-danger" role="alert">
                <%- errors %>
            </div>
        <% } %>
        
        <% if (typeof success !== 'undefined' && success.length > 0) { %>
            <div class="alert alert-success" role="alert">
                <%- success %>
            </div>
        <% } %>

        <section id="analytics" class="tab-content">
            <div class="headermenu">
                <h2>DASHBOARD</h2>
            </div>
            
            <!-- FILTER FORM -->
            <div class="filter-section">
                <form action="/adminpage" method="GET">
                    <input type="hidden" name="tab" value="analytics">
                    
                    <select name="month" class="search-input-styled">
                        <option value="">-- All Months --</option>
                        <% const months = ['January', 'February', 'March', 'April', 'May', 'June', 'July', 'August', 'September', 'October', 'November', 'December']; %>
                        <% months.forEach((m, index) => { %>
                            <option value="<%= index + 1 %>" <%= (typeof selectedMonth !== 'undefined' && selectedMonth == (index + 1)) ? 'selected' : '' %>><%= m %></option>
                        <% }); %>
                    </select>
                    
                    <select name="year" class="search-input-styled">
                        <option value="">-- All Years --</option>
                        <option value="2023" <%= (typeof selectedYear !== 'undefined' && selectedYear == '2023') ? 'selected' : '' %>>2023</option>
                        <option value="2024" <%= (typeof selectedYear !== 'undefined' && selectedYear == '2024') ? 'selected' : '' %>>2024</option>
                        <option value="2025" <%= (typeof selectedYear !== 'undefined' && selectedYear == '2025') ? 'selected' : '' %>>2025</option>
                        <option value="2026" <%= (typeof selectedYear !== 'undefined' && selectedYear == '2026') ? 'selected' : '' %>>2026</option>
                    </select>
                    <button type="submit" class="add-item-btn">Filter</button>
                    <a href="/adminpage?tab=analytics" class="add-item-btn clear-btn" style="text-decoration: none; text-align: center;">Clear</a>
                </form>
            </div>

            <!-- Stat Cards -->
            <div class="analytics-grid">
                <div class="stat-card">
                    <h4>Total Sales</h4>
                    <p>₱ <%= analyticsData.totalSales.toFixed(2) %></p>
                </div>
                <div class="stat-card">
                    <h4>Items Sold</h4>
                    <p><%= analyticsData.totalItemsSold %></p>
                </div>
                <div class="stat-card">
                    <h4>Transactions</h4>
                    <p><%= analyticsData.transactionCount %></p>
                </div>
                <div class="stat-card">
                    <h4>Best Seller</h4>
                    <p><%= analyticsData.bestSeller %></p>
                </div>
                <div class="stat-card low-stock-card">
                    <h4>Low Stock Items</h4>
                    <p><%= analyticsData.lowStockCount %></p>
                </div>
            </div>

            <!-- Charts Container -->
            <div class="charts-container">
                <div class="chart-wrapper">
                    <h3>Sales by Category</h3>
                    <% if (analyticsData.salesByCategory.length > 0) { %>
                        <canvas id="salesByCategoryChart"></canvas>
                    <% } else { %>
                        <p style="text-align: center; padding: 20px;">No sales data available to generate chart.</p>
                    <% } %>
                </div>

                <!-- NEW: Sales by Category 2 Chart -->
                <div class="chart-wrapper">
                    <h3>Sales by Category 2</h3>
                    <% if (analyticsData.salesByCategory2 && analyticsData.salesByCategory2.length > 0) { %>
                        <canvas id="salesByCategory2Chart"></canvas>
                    <% } else { %>
                        <p style="text-align: center; padding: 20px;">No data available for Category 2.</p>
                    <% } %>
                </div>

                <!-- NEW: Monthly Sales Comparison Chart -->
                <div class="chart-wrapper">
                    <h3>Monthly Sales Trend</h3>
                    <% if (analyticsData.salesByMonth && analyticsData.salesByMonth.length > 0) { %>
                        <canvas id="salesByMonthChart"></canvas>
                    <% } else { %>
                        <p style="text-align: center; padding: 20px;">No monthly data available.</p>
                    <% } %>
                </div>

                <!-- NEW: Daily Sales Trend Chart -->
                <div class="chart-wrapper">
                    <h3>Daily Sales Trend</h3>
                    <% if (analyticsData.salesByDaily && analyticsData.salesByDaily.length > 0) { %>
                        <canvas id="salesByDailyChart"></canvas>
                    <% } else { %>
                        <p style="text-align: center; padding: 20px;">No daily data available.</p>
                    <% } %>
                </div>

                <!-- NEW: Monthly Sales Trend (Category 2) Chart -->
                <div class="chart-wrapper">
                    <h3>Monthly Sales Trend (Category 2)</h3>
                    <% if (analyticsData.salesByMonthCat2 && analyticsData.salesByMonthCat2.length > 0) { %>
                        <canvas id="salesByMonthCat2Chart"></canvas>
                    <% } else { %>
                        <p style="text-align: center; padding: 20px;">No monthly data available for Category 2.</p>
                    <% } %>
                </div>

                <!-- NEW: Daily Sales Trend (Category 2) Chart -->
                <div class="chart-wrapper">
                    <h3>Daily Sales Trend (Category 2)</h3>
                    <% if (analyticsData.salesByDailyCat2 && analyticsData.salesByDailyCat2.length > 0) { %>
                        <canvas id="salesByDailyCat2Chart"></canvas>
                    <% } else { %>
                        <p style="text-align: center; padding: 20px;">No daily data available for Category 2.</p>
                    <% } %>
                </div>

                <!-- MOVED: Attendance Overview Chart -->
                <div class="chart-wrapper">
                    <h3>Attendance Overview</h3>
                    <div style="height: 300px; position: relative;">
                        <canvas id="attendanceChart"></canvas>
                    </div>
                </div>

                <!-- NEW: Late Attendance per User Chart -->
                <div class="chart-wrapper">
                    <h3>Late Attendance per User</h3>
                    <% if (analyticsData.latesPerUser && Object.keys(analyticsData.latesPerUser).length > 0) { %>
                        <canvas id="latesPerUserChart"></canvas>
                    <% } else { %>
                        <p style="text-align: center; padding: 20px;">No late records found.</p>
                    <% } %>
                </div>
            </div>
        </section>

        <section id="manning" class="tab-content">
            <div class="headermenu">
                <h2>MANNING</h2>
            </div>

            <div class="container-menu">
                <div class="container11">
                    <table class="inventory-table" id="manningTable">
                        <thead>
                            <tr>
                                <th>Username</th>
                                <th>Email</th>
                                <th>Role</th>
                                <th>Status</th>
                                <th>Remarks</th>
                                <th>Action</th>
                            </tr>
                            <tr class="filter-row">
                                <th><select class="filter-input" onchange="filterTable('manningTable')"><option value="">All</option></select></th>
                                <th><select class="filter-input" onchange="filterTable('manningTable')"><option value="">All</option></select></th>
                                <th><select class="filter-input" onchange="filterTable('manningTable')"><option value="">All</option></select></th>
                                <th><select class="filter-input" onchange="filterTable('manningTable')"><option value="">All</option></select></th>
                                <th><select class="filter-input" onchange="filterTable('manningTable')"><option value="">All</option></select></th>
                                <th></th>
                            </tr>
                        </thead>
                        <tbody>
                            <% if (typeof allUsers !== 'undefined' && allUsers.length > 0) { %>
                                <% allUsers.forEach(function(u) { %>
                                    <tr>
                                        <td><%= u.username %></td>
                                        <td><%= u.email %></td>
                                        <td><%= u.category %></td>
                                        <td><%= u.is_approved == 1 ? 'Approved' : 'Pending Approval' %></td>
                                        <td style="font-weight: bold; color: <%= u.remarks === 'AWOL' ? 'red' : (u.remarks === 'RESIGNED' ? 'orange' : 'green') %>;">
                                            <%= u.remarks %>
                                        </td>
                                        <td>
                                            <form action="/delete-user/<%= u.id %>?_method=DELETE" method="POST" style="display:inline;" onsubmit="return confirm('Are you sure you want to delete this account?')">
                                                <button type="submit" class="action-btn-delete" title="Delete Account">
                                                    <i class='bx bx-trash'></i>
                                                </button>
                                            </form>
                                            <!-- Iniba ang action route para sa Resigned -->
                                            <form action="/resign-user/<%= u.id %>" method="POST" style="display:inline;" onsubmit="return confirm('Mark this employee as Resigned?')">
                                                <button type="submit" class="action-btn-delete" style="color: orange;" title="Mark as Resigned">
                                                    <i class='bx bx-user-minus'></i>
                                                </button>
                                            </form>
                                        </td>
                                    </tr>
                                <% }); %>
                            <% } else { %>
                                <tr><td colspan="6">No user accounts found.</td></tr>
                            <% } %>
                        </tbody>
                    </table>
                </div>
            </div>
        </section>

        <section id="users" class="tab-content">
            <div class="headermenu">
                <h2>USER REGISTRATION APPROVALS</h2>
            </div>

            <div class="container-menu">
                <div class="container11">
                    <table class="inventory-table" id="usersTable">
                        <thead>
                            <tr>
                                <th>Username</th>
                                <th>Category</th>
                                <th>Email</th>
                                <th>Action</th>
                            </tr>
                        </thead>
                        <tbody>
                            <% if (typeof pendingUsers !== 'undefined' && pendingUsers.length > 0) { %>
                                <% pendingUsers.forEach(function(user) { %>
                                    <tr>
                                        <td><%= user.username %></td>
                                        <td><%= user.category %></td>
                                        <td><%= user.email %></td>
                                        <td>
                                            <form action="/approve-user/<%= user.id %>" method="POST" style="display:inline;">
                                                <button type="submit" class="add-item-btn" style="background: #2e7d32; width: auto; padding: 5px 15px; height: 35px;">Approve</button>
                                            </form>
                                            <form action="/reject-user/<%= user.id %>" method="POST" style="display:inline;" onsubmit="return confirm('Are you sure you want to reject this registration?')">
                                                <button type="submit" class="add-item-btn" style="background: #c62828; width: auto; padding: 5px 15px; height: 35px;">Reject</button>
                                            </form>
                                        </td>
                                    </tr>
                                <% }); %>
                            <% } else { %>
                                <tr><td colspan="4">No pending accounts found.</td></tr>
                            <% } %>
                        </tbody>
                    </table>
                </div>
            </div>
        </section>

        <section id="attendance" class="tab-content">
            <div class="headermenu">
                <h2>ATTENDANCE REPORTS</h2>
                <form action="/download-attendance" method="GET" class="download-btn">
                    <button type="submit">Download</button>
                </form>
            </div>

            <div class="container-menu">
                <!-- TABLE SECTION -->
                <div class="container11">
                    <table class="inventory-table" id="attendanceTable">
                        <thead>
                            <tr>
                                <th>Date</th>
                                <th>Username</th>
                                <th>Time In</th>
                                <th>Time Out</th>
                                <th>Status</th>
                                <th>Overtime</th>
                            </tr>
                            <tr class="filter-row">
                                <th><select class="filter-input" onchange="filterTable('attendanceTable')"><option value="">All</option></select></th>
                                <th><select class="filter-input" onchange="filterTable('attendanceTable')"><option value="">All</option></select></th>
                                <th><select class="filter-input" onchange="filterTable('attendanceTable')"><option value="">All</option></select></th>
                                <th><select class="filter-input" onchange="filterTable('attendanceTable')"><option value="">All</option></select></th>
                                <th><select class="filter-input" onchange="filterTable('attendanceTable')"><option value="">All</option></select></th>
                                <th><select class="filter-input" onchange="filterTable('attendanceTable')"><option value="">All</option></select></th>
                            </tr>
                        </thead>
                        <tbody>
                            <% if (typeof dtrData !== 'undefined' && dtrData.length > 0) { %>
                                <% dtrData.forEach(function(row) { %>
                                    <tr>
                                        <td><%= row.formattedDate %></td>
                                        <td><%= row.USERNAME %></td>
                                        <td><%= row['TIME IN'] %></td>
                                        <td><%= row['TIME OUT'] %></td>
                                        <td class="<%= (row.computedStatus && row.computedStatus.includes('LATE')) ? 'status-warning' : 'status-present' %>"><%= row.computedStatus %></td>
                                        <td><%= row.computedOvertime %></td>
                                    </tr>
                                <% }); %>
                            <% } else { %>
                                <tr><td colspan="6">No attendance records found.</td></tr>
                            <% } %>
                        </tbody>
                    </table>
                </div>
            </div>
        </section>

        <section id="menu" class="tab-content">
            <div class="headermenu">
                <h2>MENU</h2>
                <div class="add-menubtn">
                    <button type="button" onclick="toggleForm('add-menu')">Add Menu</button>
                </div>
            </div>

            <div class="container-menu">
                <div class="container8">
                    <div class="search-container">
                        <input type="text" id="menuSearchInput" class="search-input-styled" onkeyup="searchMenuTable()" placeholder="Search menu name, category...">
                    </div>
                    <table id="menuTable">
                        <thead>
                            <tr>
                                <th>Image</th>
                                <th>Menu Name</th>
                                <th>Category</th>
                                <th>Category 2</th>
                                <th>Price</th>
                                <th>Action</th>
                            </tr>
                        </thead>

                        <tbody>
                            <% if (typeof menuItems !== 'undefined' && menuItems.length > 0) { %>
                                <% menuItems.forEach(function(menu) { %>
                                    <tr>
                                        <td>
                                            <% if (menu.menu_image) { %>
                                                <img src="<%= menu.menu_image %>" onclick="downloadMenuImage('<%= menu.menu_image %>')" alt="menu" style="width: 50px; height: 50px; object-fit: cover; border-radius: 5px; cursor: pointer;" title="Click to download">
                                            <% } else { %>
                                                <i class='bx bx-image-alt' style="font-size: 24px; color: #ccc;"></i>
                                            <% } %>
                                        </td>
                                        <td><%= menu['Menu Name'] %></td>
                                        <td><%= menu['Category'] %></td>
                                        <td><%= menu['Category 2'] %></td>
                                        <td>₱ <%= menu['Price'] %></td>
                                        <td>
                                            <!-- Edit Button (Triggers JS) -->
                                            <button type="button" 
                                                data-id="<%= menu.id %>" 
                                                data-name="<%= menu['Menu Name'] %>" 
                                                data-category="<%= menu['Category'] %>" 
                                                data-category2="<%= menu['Category 2'] %>" 
                                                data-price="<%= menu['Price'] %>"
                                                onclick="openEditMenu(this.dataset.id, this.dataset.name, this.dataset.category, this.dataset.category2, this.dataset.price)" 
                                                class="action-btn-edit">
                                                <i class='bx bx-edit'></i>
                                            </button>
                                            
                                            <!-- Delete Button (Form) -->
                                            <form action="/delete-menu/<%= menu.id %>?_method=DELETE" method="POST" class="form-delete">
                                                <button type="submit" onclick="return confirm('Are you sure you want to delete this item?')" class="action-btn-delete">
                                                    <i class='bx bx-trash'></i>
                                                </button>
                                            </form>
                                        </td>
                                    </tr>
                                <% }); %>
                            <% } else { %>
                                <tr>
                                    <td colspan="5">No menu items found.</td>
                                </tr>
                            <% } %>
                        </tbody>
                    </table>
                </div>
                
                <!-- ADD MENU FORM (Existing) -->
                <div class="container9" id="add-menu">
                    <div>
                        <!-- Added enctype for image upload -->
                        <form action="/add-menu" method="POST" class="add-menu" enctype="multipart/form-data">
                            <h1>ADD MENU</h1>
                            <div>
                                <label for="">Menu Name :</label>
                                <input type="text" name="menu" required>
                            </div>

                            <div>
                                <label for="">Category :</label>
                                <select name="category" class="category" required>
                                    <!-- Lagyan ng value="" ang default option para gumana ang 'required' -->
                                    <option value="">-- Choose Category --</option>
                                    <option >Food</option>
                                    <option >Beverages</option>
                                    <option >Adds On</option>
                                </select>
                            </div>

                            <div>
                                <label for="">Category 2 :</label>
                                <select name="category2" class="category" required>
                                    <!-- Lagyan ng value="" ang default option para gumana ang 'required' -->
                                    <option value="">-- Choose Category --</option>
                                    <option >Fried chicken</option>
                                    <option >Snack bar</option>
                                    <option >Ramen & Pasta</option>
                                    <option >Rice Meal Bundle</option>
                                    <option >Coffee Based Drinks</option>
                                    <option >Milk Based Drinks</option>
                                    <option >Soda Drinks</option>
                                    <option >Cheese Cake Series</option>
                                    <option >Smoothies</option>
                                    <option >Adds On</option>
                                </select>
                            </div>

                            <div>
                                <label for="price">Price :</label>
                                <input type="number" id="price" name="Price" step="0.01" min="0" placeholder="0.00" required>
                            </div>

                            <div>
                                <label for="menu_image">Menu Image :</label>
                                <input type="file" name="menu_image" id="menu_image" accept="image/*">
                            </div>

                            <button>Add Menu</button>
                        </form>
                    </div>
                </div>

                <!-- EDIT MENU FORM (New Hidden Form) -->
                <div class="container9" id="edit-menu">
                    <div>
                        <!-- ACTION: /update-menu, METHOD: PUT -->
                        <form action="/update-menu?_method=PUT" method="POST" class="add-menu" id="edit-menu-form" enctype="multipart/form-data">
                            <h1>EDIT MENU</h1>
                            <!-- Hidden Input for ID -->
                            <input type="hidden" name="id">

                            <div>
                                <label for="">Menu Name :</label>
                                <input type="text" name="menu" required>
                            </div>
 
                            <div>
                                <label for="">Category :</label>
                                <select name="category" class="category" required>
                                    <option value="">-- Choose Category --</option>
                                    <option value="Food">Food</option>
                                    <option value="Beverages">Beverages</option>
                                    <option value="Adds On">Adds On</option>
                                </select>
                            </div>

                            <div>
                                <label for="">Category 2 :</label>
                                <select name="category2" class="category" required>
                                    <option value="">-- Choose Category --</option>
                                    <option >Fried chicken</option>
                                    <option >Snack bar</option>
                                    <option >Ramen & Pasta</option>
                                    <option >Rice Meal Bundle</option>
                                    <option >Coffee Based Drinks</option>
                                    <option >Milk Based Drinks</option>
                                    <option >Soda Drinks</option>
                                    <option >Cheese Cake Series</option>
                                    <option >Smoothies</option>
                                    <option >Adds On</option>
                                </select>
                            </div>
                            

                            <div>
                                <label for="edit-price">Price :</label>
                                <input type="number" id="edit-price" name="Price" step="0.01" min="0" placeholder="0.00" required>
                            </div>

                            <div>
                                <label for="edit_menu_image">Update Menu Image :</label>
                                <input type="file" name="menu_image" id="edit_menu_image" accept="image/*">
                            </div>

                            <button type="submit" class="btn-blue">Update Menu</button>
                        </form>
                    </div>
                </div>
            </div>

        </section> 

        <section id="inventory" class="tab-content">
            <div class="headermenu">
                <h2>INVENTORY</h2>
            </div>

            <div class="container-menu">
                <div class="container4">
                    <table class="inventory-table" id="inventoryTable">
                        <thead>
                            <tr>
                                <th>Date</th>
                                <th>Item Name</th>
                                <th>Item Category</th>
                                <th>Unit of Measurement</th>
                                <th>Stock On Hand</th>
                                <th>User</th>
                                <th>Remarks</th>
                                <th>Action</th>
                            </tr>
                            <tr class="filter-row">
                                <th><select class="filter-input" onchange="filterTable('inventoryTable')"><option value="">All</option></select></th>
                                <th><select class="filter-input" onchange="filterTable('inventoryTable')"><option value="">All</option></select></th>
                                <th><select class="filter-input" onchange="filterTable('inventoryTable')"><option value="">All</option></select></th>
                                <th><select class="filter-input" onchange="filterTable('inventoryTable')"><option value="">All</option></select></th>
                                <th><select class="filter-input" onchange="filterTable('inventoryTable')"><option value="">All</option></select></th>
                                <th><select class="filter-input" onchange="filterTable('inventoryTable')"><option value="">All</option></select></th>
                                <th><select class="filter-input" onchange="filterTable('inventoryTable')"><option value="">All</option></select></th>
                                <th></th> <!-- No filter for Action -->
                            </tr>
                        </thead>

                        <tbody>
                           <% if (typeof items !== 'undefined' && items.length > 0) { %>
                               <% items.forEach(function(item) { %>
                                   <tr>
                                       <td><%= item.DATE %></td>
                                       <td><%= item.ITEM_NAME %></td>
                                       <td><%= item.ITEM_CATEGORY %></td>
                                       <td><%= item.UNIT_OF_MEASURE %></td>
                                       <td><%= item.STOCK_ONHAND %></td>
                                       <td><%= item.USERNAME || 'N/A' %></td>
                                       <td class="remarks-cell <%= item.REMARKS === 'LOW STOCK' ? 'low-stock' : (item.REMARKS ? 'in-stock' : 'no-remarks') %>">
                                           <%= item.REMARKS || 'N/A' %>
                                       </td>
                                       <td>
                                           <!-- Action Form: Mag-aadd ng stock -->
                                           <form action="/mark-new-stock" method="POST" class="form-center-flex">
                                               <input type="hidden" name="id" value="<%= item.id %>">
                                               <!-- Check Box Button Action -->
                                               <button type="submit" title="Mark as New Stock" class="btn-icon-transparent">
                                                   <i class='bx <%= item.REMARKS === "NEW STOCKS" ? "bx-check-square" : "bx-square" %> icon-large'></i>
                                               </button>
                                           </form>
                                       </td>
                                   </tr>
                                <% }); %>
                            <% } else { %>
                             <tr>
                                <td colspan="8">No items found.</td>
                            </tr>
                          <% } %>
                        </tbody>
                        
                    </table>
                </div>
            </div>
        </section>

        <section id="sellout" class="tab-content">
            <div class="headermenu">
                <h2>SELLOUT REPORTS</h2>
                <form action="/download-sellout" method="GET" class="download-btn">
                    <button type="submit" >Download</button>
                </form>
            </div>

            <div class="container-menu">
                <div class="container11">
                    <table class="inventory-table" id="selloutTable">
